{
  "name": "review-service",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "start:migrate": "prisma migrate deploy && node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node --env-file-if-exists=.env prisma/seed.js",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@vercel/blob": "^2.5.0",
    "hono": "^4.12.0",
    "pg": "8.22.0",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/pg": "8.20.0",
    "prisma": "7.8.0",
    "tsx": "^4.23.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13"
  }
}
